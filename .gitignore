# ── Personal data — NEVER commit (this is the whole point) ───────────────────
profile/master_cv.yaml
profile/master_cv.*.yaml
# Keep the committed template the setup steps tell you to copy (negation must be its own line):
!profile/master_cv.example.yaml
config/criteria.md
config/companies.yaml
config/sources.local.yaml
data/
!data/.gitkeep
# The "data" DOMAIN seed pack is committed repo content (a template), not personal data —
# re-include it despite the data/ rule above (negation must override; keep this line after it).
!config/seeds/data/
# Per-profile runtime state (DB, config, master CV, registry). Committed seeds stay at
# the repo root (config/*.example.*, config/sources.yaml, profile/master_cv.example.yaml).
profiles/
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
inbox/
outbox/
**/Connections.csv
**/connections*.csv
*.docx
*.pdf
.env
.env.local

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
build/
dist/

# ── Node / Vite (dashboard frontend) ─────────────────────────────────────────
node_modules/
dashboard/frontend/dist/
dashboard/frontend/.vite/
*.local

# ── macOS / editors ──────────────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp

# ── Tooling (graphify knowledge graph + git worktrees) ───────────────────────
graphify-out/
.claude/worktrees/
