# Copy to .env and fill in. .env is gitignored. All optional — Atlas runs at $0
# without any of these; they only unlock extra (free-tier) discovery sources.

# Adzuna free API (https://developer.adzuna.com/) — multi-country listings + salary.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Optional: override default data dir (defaults to ./data next to the repo).
# ATLAS_DATA_DIR=

# NOTE: Atlas deliberately uses NO Anthropic API key. The recurring "brain" runs
# as a Claude Cowork/Desktop scheduled task on your subscription. If you ever see
# ANTHROPIC_API_KEY set in your shell, `atlas doctor` will warn you — that key is
# the documented cause of accidental per-token billing.
